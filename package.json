{
  "name": "mirae-bizon-analyzer",
  "version": "1.0.0",
  "description": "미래비즈온 AI 타지역서비스 분석툴",
  "main": "main.js",
  "author": "미래비즈온",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64 --publish never"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.miraebiz.analyzer",
    "productName": "MiraeBizon-AI-Analyzer",
    "copyright": "Copyright © 2026 미래비즈온",
    "directories": { "output": "dist" },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico",
      "artifactName": "MiraeBizon-AI-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "미래비즈온 AI분석툴"
    },
    "files": ["main.js","preload.js","splash.html","license.html","assets/**/*"]
  }
}
